NODE_ENV=development

# Server
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=translator_db
DB_USER=root
DB_PASSWORD=your_password_here

# Email Service (Nodemailer)
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password

# JWT Secrets
JWT_SECRET=your-secret-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-this-in-production

# OpenAI (2-pass: correction + translation)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_CORRECTION_MODEL=gpt-4.1-nano

# Deepgram STT (Nova-3, Korean)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_LANGUAGE=ko
DEEPGRAM_SMART_FORMAT=true
DEEPGRAM_PUNCTUATE=true
STT_PROMPT_TEMPLATE=church
